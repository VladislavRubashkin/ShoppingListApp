<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ShoppingListApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="CustomActionBar.Title" parent="@android:style/TextAppearance.Holo.Widget.ActionBar.Title">
        <item name="android:fontFamily">@font/amiko_semibold</item>
        <item name="android:textSize">20sp</item>
        <item name="color">@color/black</item>
    </style>

    <style name="CustomActionBarStyle" parent="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"><!--Widget.Holo.Light.ActionBar.Solid.Inverse -->
        <item name="android:background">@color/black</item><!-- ?attr/colorSecondary-->
        <item name="android:titleTextStyle">@style/CustomActionBar.Title</item>
    </style>




    <style name="Theme.MyFloatingActionButton" parent="@style/Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">?attr/colorSecondary</item>
    </style>

    <style name="MyStyle.Preference.v21" parent="@style/PreferenceThemeOverlay.v14.Material">
        <item name="android:tint">?attr/colorSecondary</item>
    </style>

<!--    <attr name="myButtonBackgroundTint" format="color|reference"/>-->

    <style name="Theme.ShoppingListDark" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/blue_main_light</item>
        <item name="colorPrimaryVariant">@color/blue_main_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/blue_main_light</item>
        <item name="colorSecondaryVariant">@color/blue_main_light</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>


        <item name="android:windowActionBarOverlay">true</item>
        <item name="preferenceTheme">@style/MyStyle.Preference.v21</item>
        <item name="android:actionButtonStyle">@style/Theme.MyFloatingActionButton</item>
        <item name="android:actionBarTheme">@style/CustomActionBarStyle</item>


    </style>

    <style name="Theme.ShoppingListLight" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/green_main_light</item>
        <item name="colorPrimaryVariant">@color/green_main_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/green_main_dark</item>
        <item name="colorSecondaryVariant">@color/green_main_dark</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>


        <item name="android:windowActionBarOverlay">true</item>
        <item name="preferenceTheme">@style/MyStyle.Preference.v21</item>
        <item name="android:actionButtonStyle">@style/Theme.MyFloatingActionButton</item>
        <item name="actionBarStyle">@style/CustomActionBarStyle</item>

    </style>
</resources>